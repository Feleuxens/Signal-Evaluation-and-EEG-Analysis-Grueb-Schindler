[bad_channels]
enabled = true
# z-score threshold for bad channel detection
z_thresh = 3.0
# Prefix for external channels to exclude from EEG analysis
exg_prefix = "EXG"
# Prefix for status channels to exclude from EEG analysis
status_prefix = "Status"

[filtering]
enabled = true
pass_filter_enabled = true
low_pass = 40.0
high_pass = 0.1
pass_filter_method = "firwin"
pass_filter_pick = "eeg"
notch_filter_enabled = true
notch_frequencies = [50, 100, 150, 200]
notch_filter_method = "spectrum_fit"
notch_filter_pick = "eeg"

[downsampling]
enabled = true
target_sfreq = 128
npad = "auto"

[rereferencing]
enabled = true
ref_channels = "average"
projection = false

[asr]
enabled = false

[ica]
enabled = true
n_components = 0.99

[interpolation]
enabled = true
reset_bads = false
mode = "accurate"

[epoching]
epochrange_tmin = -0.5
epochrange_tmax = 1.0
baseline = [-0.25, 0.0]

[trial_rejection]
enabled = true
eeg_threshold = 150e-6
eog_threshold = 250e-6
flat_threshold = 1e-6
